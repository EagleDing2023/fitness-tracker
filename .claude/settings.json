{
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-haiku-4-5",
    "ENABLE_PROMPT_CACHING_1H": "0"
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Edit(src/**)",
      "Edit(app/**)",
      "Edit(components/**)",
      "Edit(lib/**)",
      "Edit(tests/**)",
      "Edit(*.md)",
      "Edit(.claude/**)",
      "Write(src/**)",
      "Write(app/**)",
      "Write(components/**)",
      "Write(lib/**)",
      "Write(tests/**)",
      "Write(SPEC.md)",
      "Write(PLAN.md)",
      "Write(INFRA.md)",
      "Write(.env.local)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout -b*)",
      "Bash(git branch*)",
      "Bash(bun install*)",
      "Bash(bun add*)",
      "Bash(bun run*)",
      "Bash(bun dev*)",
      "Bash(bun test*)",
      "Bash(bun typecheck*)",
      "Bash(bun lint*)",
      "Bash(bunx drizzle-kit push)",
      "Bash(bunx drizzle-kit generate*)",
      "Bash(bunx shadcn*)",
      "Bash(npm install*)",
      "Bash(npx *)",
      "Bash(vercel)",
      "Bash(vercel link)",
      "Bash(vercel env*)",
      "Bash(gh repo view*)",
      "Bash(gh pr list*)",
      "Bash(gh issue list*)",
      "WebFetch(domain:docs.*.com)",
      "WebFetch(domain:github.com)",
      "mcp__context7__*",
      "mcp__shadcn__*",
      "mcp__supabase__*",
      "mcp__playwright__*"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(sudo *)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(* > /dev/sda*)",
      "Bash(dd *)",
      "Bash(vercel --prod)",
      "Bash(bunx drizzle-kit drop*)",
      "Edit(.env)",
      "Edit(.env.production)",
      "Edit(migrations/**)",
      "Write(.env)",
      "Write(.env.production)",
      "Write(migrations/**)",
      "Write(node_modules/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); echo \"$INPUT\" | grep -qE '(sk-ant-|sk-proj-|service_role.*supabase)' && { echo 'Secret pattern detected in write content - blocking' >&2; exit 2; } || exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.test.ts)",
            "command": "bun test --bail 2>&1 | tail -30"
          },
          {
            "type": "command",
            "if": "Edit(*.test.tsx)",
            "command": "bun test --bail 2>&1 | tail -30"
          },
          {
            "type": "command",
            "if": "Write(*.test.ts)",
            "command": "bun test --bail 2>&1 | tail -30"
          },
          {
            "type": "command",
            "if": "Write(*.test.tsx)",
            "command": "bun test --bail 2>&1 | tail -30"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Reminder: announce current phase, never invent APIs, /clear after 2 failed corrections'"
          }
        ]
      }
    ]
  }
}